digraph schema {
  rankdir=LR;
  graph [bgcolor="white", splines=spline, nodesep=0.5, ranksep=1.4, pad=0.5];
  node [shape=plaintext, fontname="Helvetica", fontsize=11];
  edge [color="#64748b", penwidth=1.1, arrowhead=normal, arrowtail=odot, dir=both];

  "bar_codes" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD BGCOLOR="#1f2937"><FONT COLOR="white"><B>bar_codes</B></FONT></TD></TR><TR><TD ALIGN="LEFT" BGCOLOR="#fde68a" PORT="id">id  (PK)</TD></TR><TR><TD ALIGN="LEFT" BGCOLOR="#dbeafe" PORT="item_id">item_id  (FK)</TD></TR><TR><TD ALIGN="LEFT" BGCOLOR="#ffffff" PORT="bar_code">bar_code</TD></TR><TR><TD ALIGN="LEFT" BGCOLOR="#ffffff" PORT="is_active">is_active</TD></TR><TR><TD ALIGN="LEFT" BGCOLOR="#ffffff" PORT="description">description</TD></TR><TR><TD ALIGN="LEFT" BGCOLOR="#ffffff" PORT="created_at">created_at</TD></TR><TR><TD ALIGN="LEFT" BGCOLOR="#ffffff" PORT="updated_at">updated_at</TD></TR></TABLE>>];
